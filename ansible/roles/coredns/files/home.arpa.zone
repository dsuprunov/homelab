$ORIGIN home.arpa.
$TTL 300
@       IN SOA  ns.home.arpa. admin.home.arpa. (
                2026060603 ; serial
                3600       ; refresh
                600        ; retry
                604800     ; expire
                300        ; minimum
)
                    IN NS     ns.home.arpa.

ns                  IN A      192.168.178.206

vm-coredns          IN A      192.168.178.206

s3                  IN CNAME  vm-garage-01.home.arpa.
vm-garage-01        IN A      192.168.178.207

vault               IN CNAME  vm-vault-01.home.arpa.
vm-vault-01         IN A      192.168.178.208

k8s-api             IN A      192.168.178.230
vm-k8s-control-01   IN A      192.168.178.231
vm-k8s-control-02   IN A      192.168.178.232
vm-k8s-control-03   IN A      192.168.178.233
vm-k8s-worker-01    IN A      192.168.178.236
vm-k8s-worker-02    IN A      192.168.178.237
vm-k8s-worker-03    IN A      192.168.178.238

grafana.k8s                           IN A      192.168.178.246
argocd.k8s                            IN A      192.168.178.246

demo-website.k8s                      IN A      192.168.178.246
demo-website-blue-green.k8s           IN A      192.168.178.246
demo-website-blue-green-preview.k8s   IN A      192.168.178.246
demo-website-canary.k8s               IN A      192.168.178.246
